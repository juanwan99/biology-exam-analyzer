DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro
QWEN_API_KEY=sk-your-qwen-key
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_TEXT_MODEL=qwen-plus
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DATABASE_URL=postgresql://user:pass@localhost:5432/biology_exam
SECRET_KEY=your-secret-key
ADMIN_PASSWORD=your-admin-password

# LLM Provider
# Default LLM analysis chain: DeepSeek V4 Pro is the text reviewer.
# Qwen is reserved for visual preprocessing; Qwen text fallback is opt-in only.
LLM_SA_CREDENTIALS=/app/.credentials/sa-key.json
LLM_PROJECT=your-project-id
LLM_LOCATION=global
LLM_SDK_MODULE=your-sdk-module
LLM_CLOUD_MODE=false
LLM_ENABLE_QWEN_TEXT_FALLBACK=false
LLM_ENABLE_NATIVE_TEXT_FALLBACK=false
LLM_EXAM_REVIEW_FLASH_MODEL=your-flash-model
LLM_EXAM_REVIEW_PRO_MODEL=your-pro-model
LLM_ALLOW_NATIVE_MODEL_OVERRIDE=false
LLM_NATIVE_MODEL=
LLM_API_KEY=your-api-key
LLM_VISION_PROVIDER=qwen
